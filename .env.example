# =============================================================
#  CLAVES DE API DE BINANCE
# =============================================================
# Copia este archivo a ".env" (sin el .example) y rellena tus claves.
# NUNCA compartas este archivo ni lo subas a internet.
#
# Necesitas DOS pares de claves distintos:
#
#  1) TESTNET (dinero de mentira, para practicar) -> https://testnet.binance.vision/
#  2) REAL    (dinero de verdad)                  -> https://www.binance.com/  (perfil > API Management)
#
# El bot usará automáticamente las de testnet mientras estés en modo
# "paper", y las reales solo cuando pongas modo "live" a propósito.
# =============================================================

# --- Claves de TESTNET (practica sin riesgo) ---
BINANCE_TESTNET_API_KEY=pon_aqui_tu_clave_de_testnet
BINANCE_TESTNET_API_SECRET=pon_aqui_tu_secreto_de_testnet

# --- Claves REALES (dinero de verdad) ---
# Déjalas vacías hasta que de verdad quieras operar con dinero real.
# IMPORTANTE: al crear la clave real, activa SOLO permisos de trading
# spot. NUNCA actives "retiros/withdrawals".
BINANCE_API_KEY=
BINANCE_API_SECRET=
